# SharpWallet — Environment Variables
# Copy this to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Alert thresholds
MIN_BET_SIZE_USDC=1000       # minimum bet to trigger alert
MIN_WALLET_SCORE=60          # minimum composite score to monitor
MIN_CATEGORY_MARKETS=15      # min markets in a category to trust category score

# Sportsbook (Phase 3)
ODDS_API_KEY=your-odds-api-key
